# ~/dotfiles/git/gitconfig-auditore.example
#
# Template versionado. O install.sh gera o gitconfig-auditore real
# substituindo {{AUDITORE_EMAIL}} pelo seu email corporativo.
# O arquivo real é gitignored.
#
# Carregado via includeIf quando o repo está em ~/ws/auditore/ ou ~/ws/byd/

[user]
	email = {{AUDITORE_EMAIL}}

# Adicione aqui qualquer config específica do contexto Auditore.
# Exemplo: signing key diferente, hooks, etc.
#
# [user]
#   signingkey = SUA_GPG_KEY_AUDITORE
# [commit]
#   gpgsign = true
